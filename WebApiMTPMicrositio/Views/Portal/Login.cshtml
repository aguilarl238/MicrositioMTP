@model MTPMicrositio.Models.Web.LoginViewModel
@{ Layout = "~/Views/Shared/_LayoutLogin.cshtml"; ViewBag.Title = "Consola Global MTP"; }
<style>
    :root {
        --mtp-dark: #0f172a; /* Slate 900 */
        --mtp-primary: #1e3a8a; /* Azul Marino Corporativo */
        --mtp-accent: #06b6d4; /* Cian Eléctrico Tecnológico */
        --mtp-light: #f8fafc; /* Blanco Grisáceo */
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, var(--mtp-dark) 0%, #1e293b 100%);
        min-height: 100vh;
        color: #ffffff;
    }

    .login-card {
        background-color: #ffffff;
        border: 1px solid rgba(6, 182, 212, 0.2);
        border-radius: 12px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
        transition: border-color 0.3s ease;
    }

        .login-card:hover {
            border-color: var(--mtp-accent);
        }

    .form-control {
        border: 1px solid #cbd5e1;
        padding: 0.75rem 1rem;
        transition: all 0.2s ease;
    }

        .form-control:focus {
            border-color: var(--mtp-accent);
            box-shadow: 0 0 0 0.25rem rgba(6, 182, 212, 0.15);
            color: #1e293b;
        }

    .btn-tech {
        background-color: var(--mtp-primary);
        color: #ffffff;
        font-weight: 600;
        padding: 0.75rem;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-tech:hover {
            background-color: #172554;
            color: var(--mtp-accent);
            box-shadow: 0 4px 12px rgba(6, 182, 212, 0.2);
        }

    .text-accent {
        color: var(--mtp-accent);
    }

    .border-accent-left {
        border-left: 3px solid var(--mtp-accent);
    }
</style>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12 col-sm-10 col-md-8 col-lg-5 col-xl-4">

            <div class="card login-card text-dark p-4 p-sm-5">

                <div class="text-center mb-4">
                    <h2 class="fw-bold text-primary mb-1 text-uppercase tracking-wide">MTP</h2>                
    @*<div class="nav-logo"><img src="data:image/png;base64," alt="MTP Internacional" style="height:36px;"></div>*@
                    <p class="text-muted small border-accent-left ps-2 d-inline-block">Digital Business Assurance</p>
                </div>

                @* Apertura del Formulario apuntando a la Acción Login del Controlador Account *@
                @using (Html.BeginForm("Login", "Portal", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
                {
                    @Html.AntiForgeryToken()

                    @* Resumen global de errores (ej. "Credenciales incorrectas") *@
                    @Html.ValidationSummary(true, "", new { @class = "text-danger small mb-3" })

                    <div class="mb-3">
                        @Html.LabelFor(m => m.Email, new { @class = "form-label fw-semibold text-secondary small" })
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control text-dark", @placeholder = "nombre@empresa.com", @type = "email", autocomplete = "username" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small" })
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            @Html.LabelFor(m => m.Password, new { @class = "form-label fw-semibold text-secondary small mb-0" })
                            <a href="#" class="text-accent small text-decoration-none" onclick="alert('Funcionalidad de recuperación simulada. Contacte a soporte MTP.')">¿La olvidaste?</a>
                        </div>
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control text-dark", @placeholder = "••••••••", autocomplete = "current-password" })
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
                    </div>

                    @* <div class="mb-4 form-check">
                            <input type="checkbox" class="form-check-input" id="rememberMe">
                            <label class="form-check-label text-muted small" for="rememberMe">Recordar mis credenciales</label>
                        </div>
                    *@

                    <div class="d-grid">
                        <button type="submit" class="btn btn-tech text-uppercase btn-lg fs-6">
                            Acceder al Portal &rarr;
                        </button>
                    </div>
                }

                <div class="text-center mt-4 border-top pt-3">
                    <p class="text-muted small mb-0">¿No tienes cuenta asignada?</p>
                    <a href="@Url.Action("Contacto", "Home")" class="text-primary fw-semibold small text-decoration-none">Solicita acceso aquí</a>
                </div>

            </div>

            <div class="text-center mt-4">
                <a href="@Url.Action("Index", "Home")" class="text-muted text-decoration-none small transition-all" style="color: #94a3b8 !important;">&larr; Volver al sitio público</a>
            </div>

        </div>
    </div>
</div>