<!-- HERO -->
<section class="hero">
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="hero-left">
        <div class="hero-badge">
            <div class="hero-badge-dot"></div>
            Líderes globales en calidad digital
        </div>
        <h1 class="hero-h1">Tu software <em>funciona</em>,<br>se entrega a tiempo<br>y evoluciona contigo.</h1>
        <p class="hero-sub">Eso es Digital Business Assurance. Desde 1997 acompañamos a organizaciones líderes en América y Europa — con el equipo, la metodología y las certificaciones para garantizarlo.</p>
        <div class="hero-btns">
            <a class="btn-primary">Conoce nuestros servicios</a>
            <a class="btn-secondary">Acceso al Portal</a>
        </div>
    </div>
    <div class="hero-right">
        <div class="terminal">
            <div class="terminal-bar">
                <div class="terminal-dot" style="background:#FF5F57;"></div>
                <div class="terminal-dot" style="background:#FFBD2E;"></div>
                <div class="terminal-dot" style="background:#28C840;"></div>
                <span class="terminal-filename">mtp_qa_analyzer.py</span>
            </div>
            <div class="terminal-body">
                <div><span class="t-comment">## MTP Quality Assurance Engine v2.0</span></div>
                <div><span class="t-muted">→ </span><span class="t-green">iniciando</span> <span class="t-white">análisis de cobertura...</span></div>
                <div><span class="t-muted">→ </span><span class="t-white">casos de prueba detectados: </span><span class="t-yellow">1,284</span></div>
                <div><span class="t-muted">→ </span><span class="t-white">cobertura funcional: </span><span class="t-green">98.4%</span></div>
                <div><span class="t-muted">→ </span><span class="t-white">defectos críticos: </span><span class="t-green">0</span></div>
                <div><span class="t-muted">→ </span><span class="t-white">metodología: </span><span class="t-green">OMNIATEST TMMi 5</span></div>
                <div><span class="t-muted">→ </span><span class="t-green">✓ release aprobado</span> <span class="t-white">para producción</span></div>
                <div style="margin-top:4px;"><span class="cursor">█</span></div>
            </div>
        </div>
    </div>
</section>

<!-- MÉTRICAS -->
<div class="metrics">
    <div class="metric">
        <div class="metric-num"><em>1997</em></div>
        <div class="metric-label">Año de fundación</div>
        <div class="metric-tag">Desde siempre</div>
    </div>
    <div class="metric">
        <div class="metric-num">+<em>2,000</em></div>
        <div class="metric-label">Profesionales especializados</div>
        <div class="metric-tag">Global</div>
    </div>
    <div class="metric">
        <div class="metric-num">+<em>3,000</em></div>
        <div class="metric-label">Proyectos exitosos</div>
        <div class="metric-tag">América y Europa</div>
    </div>
    <div class="metric">
        <div class="metric-num"><em>TMMi 5</em></div>
        <div class="metric-label">Certificación más alta del mundo</div>
        <div class="metric-tag">Primeros globalmente</div>
    </div>
</div>

<!-- SERVICIOS -->
<div class="services">
    <div class="section-label">Qué hacemos</div>
    <div class="section-title">Tres verticales, <em>un mismo estándar</em> de calidad</div>
    <div class="cards">
        <div class="card">
            <div class="card-accent" style="background: linear-gradient(90deg,#1B7A61,#3ECBAD);"></div>
            <div class="card-icon" style="background:#E8F7F3;">🧪</div>
            <div class="card-title">Quality Assurance</div>
            <div class="card-desc">Pruebas funcionales, automatización, performance, seguridad y mobile. Certificados TMMi Nivel 5.</div>
            <div class="card-link">Ver servicios →</div>
        </div>
        <div class="card">
            <div class="card-accent" style="background: linear-gradient(90deg,#1B2E4B,#3A6EA8);"></div>
            <div class="card-icon" style="background:#EEF2F8;">⚙️</div>
            <div class="card-title">Ingeniería de Software</div>
            <div class="card-desc">Desarrollo a la medida, modernización de legados, APIs, microservicios y habilitación en Azure.</div>
            <div class="card-link">Ver servicios →</div>
        </div>
        <div class="card">
            <div class="card-accent" style="background: linear-gradient(90deg,#5A3E8A,#8B65C8);"></div>
            <div class="card-icon" style="background:#F2EEF8;">💡</div>
            <div class="card-title">Consultoría</div>
            <div class="card-desc">Assessment de madurez, DevSecOps, cumplimiento normativo e implementación de mejores prácticas.</div>
            <div class="card-link">Ver servicios →</div>
        </div>
    </div>
</div>

<!-- CTA BANNER -->
<div class="cta-banner">
    <div class="cta-banner-left">
        <h2>¿Listo para <em>elevar la calidad</em> de tu software?</h2>
        <p>Cuéntanos el reto. Nosotros proponemos el camino.</p>
    </div>
    <div class="cta-banner-btn">Hablar con un especialista</div>
</div>

  </div>

