<style>
/* Como trabajamos */
:root {
    --primary-color: #0066ff;
    --secondary-color: #00f2fe;
    --text-main: #333333;
    --text-muted: #666666;
    --bg-card: #ffffff;
    --bg-section: #f8fafc;
}

/* Estructura Base */
.circular-workflow-section {
    background-color: var(--bg-section);
    padding: 80px 20px;
    font-family: 'Segoe UI', system-ui, sans-serif;
    overflow: hidden;
}

.max-container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
}

.section-label {
    text-transform: uppercase;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--primary-color);
    letter-spacing: 2px;
    margin-bottom: 10px;
}

.section-title {
    font-size: 2.2rem;
    color: var(--text-main);
    margin-bottom: 15px;
}

.section-sub {
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto 60px auto;
    font-size: 1.1rem;
}

.highlight {
    font-weight: 600;
    color: var(--primary-color);
}

.phase-badge {
    display: inline-block;
    background: rgba(0, 102, 255, 0.1);
    color: var(--primary-color);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 10px;
}

/* Rueda e Ítems (Desktop) */
.wheel-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 40px 0;
}

.wheel-container {
    position: relative;
    width: 750px;
    height: 750px;
    border: 2px dashed rgba(0, 102, 255, 0.2);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
}

/* Núcleo Central */
.wheel-center {
    position: absolute;
    width: 140px;
    height: 140px;
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    color: white;
    box-shadow: 0 10px 30px rgba(0, 102, 255, 0.3);
    z-index: 10;
}

.center-content strong {
    display: block;
    font-size: 1.8rem;
    letter-spacing: 1px;
}

.center-content span {
    font-size: 0.85rem;
    opacity: 0.9;
}

/* Posicionamiento Circular de Tarjetas */
.wheel-item {
    position: absolute;
    width: 320px;
    transition: transform 0.3s ease;
}

/* Distribución matemática en los 4 cuadrantes del círculo */
.phase-1 {
    top: 0;
    left: 50%;
    transform: translate(-50%, -40px);
}

.phase-2 {
    top: 50%;
    right: 0;
    transform: translate(160px, -50%);
}

.phase-3 {
    bottom: 0;
    left: 50%;
    transform: translate(-50%, 40px);
}

.phase-4 {
    top: 50%;
    left: 0;
    transform: translate(-160px, -50%);
}

/* Tarjetas de Contenido */
.wheel-card {
    background: var(--bg-card);
    padding: 24px;
    border-radius: 16px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    text-align: left;
    border: 1px solid rgba(0,0,0,0.03);
    position: relative;
}

.wheel-item:hover .wheel-card {
    box-shadow: 0 15px 35px rgba(0, 102, 255, 0.15);
    border-color: rgba(0, 102, 255, 0.2);
}

.wheel-card h3 {
    font-size: 1.15rem;
    margin: 5px 0 10px 0;
    color: var(--text-main);
}

.wheel-card p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.4;
    margin-bottom: 12px;
}

/* Burbujas Numéricas */
.wheel-dot {
    position: absolute;
    width: 36px;
    height: 36px;
    background: var(--primary-color);
    color: white;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-weight: bold;
    font-size: 0.9rem;
    z-index: 5;
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
}
/* Ubicación del número respecto a cada tarjeta */
.phase-1 .wheel-dot {
    bottom: -18px;
    left: 50%;
    transform: translateX(-50%);
}

.phase-2 .wheel-dot {
    left: -18px;
    top: 50%;
    transform: translateY(-50%);
}

.phase-3 .wheel-dot {
    top: -18px;
    left: 50%;
    transform: translateX(-50%);
}

.phase-4 .wheel-dot {
    right: -18px;
    top: 50%;
    transform: translateY(-50%);
}

/* Entregables en formato micro-tags */
.wheel-deliverables {
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-top: 1px solid #f0f0f0;
    padding-top: 10px;
}

    .wheel-deliverables span {
        font-size: 0.8rem;
        color: var(--text-main);
        font-weight: 500;
    }

</style>