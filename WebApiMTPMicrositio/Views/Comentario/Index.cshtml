@model MTPMicrositio.Models.Web.ComentarioFiltroViewModel
@{ Layout = "~/Views/Shared/_LayoutPortal.cshtml"; ViewBag.Title = "Bitácora Tecnológica"; }

<div class="card p-4 bg-white border-0 mb-4 shadow-sm">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="fw-bold text-dark mb-0"><i class="bi bi-chat-left-text text-primary me-2"></i>Bitácora de Seguimiento de Proyectos</h4>
            <p class="text-muted small mb-0">Revisión de alcances técnicos y estatus contractual de MTP.</p>
        </div>
        <a href="@Url.Action("Insertar")" class="btn btn-sm btn-primary px-3"><i class="bi bi-plus-lg me-1"></i>Nuevo Comentario</a>
    </div>

    @using (Html.BeginForm("Index", "Comentario", FormMethod.Get, new { @class = "row g-2 p-3 bg-light rounded border align-items-end" }))
    {
        <div class="col-md-3">
            <label class="form-label small fw-bold text-secondary">Proyecto</label>
            @Html.DropDownListFor(m => m.FiltrarProyectoId, Model.ListaProyectos, "-- Todos --", new { @class = "form-select form-select-sm" })
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-bold text-secondary">Prioridad</label>
            @Html.DropDownListFor(m => m.FiltrarPrioridadId, Model.ListaPrioridades, "-- Todas --", new { @class = "form-select form-select-sm" })
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-bold text-secondary">Estatus</label>
            @Html.DropDownListFor(m => m.FiltrarEstatusId, Model.ListaEstatus, "-- Todos --", new { @class = "form-select form-select-sm" })
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-dark w-100 fw-semibold"><i class="bi bi-funnel me-1"></i>Filtrar</button>
            <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary w-100 fw-semibold">Limpiar</a>
        </div>
    }
</div>

<div class="card p-4 bg-white border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Descripción</th>
                    <th>Fecha</th>
                    <th class="text-center">Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Comentarios != null && Model.Comentarios.Any())
                {
                    foreach (var item in Model.Comentarios)
                    {
                        <tr>
                            <td style="max-width: 400px;" class="text-truncate">@item.Descripcion</td>
                            <td>@(item.Fecha?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                            <td class="text-center">
                                <span class="badge @(item.Activo ? "bg-success" : "bg-secondary")">@(item.Activo ? "Activo" : "Inactivo")</span>
                            </td>
                            <td class="text-end">
                                <a href="@Url.Action("Editar", new { id = item.ComentarioId })" class="btn btn-sm btn-outline-secondary px-2"><i class="bi bi-pencil"></i></a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="4" class="text-center py-4 text-muted">Ningún registro coincide con el triple filtro seleccionado.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>