@model MTPMicrositio.Models.Web.ComentarioViewModel
@{ Layout = "~/Views/Shared/_LayoutPortal.cshtml"; ViewBag.Title = "Editar Nota"; }

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card p-4 p-md-5 bg-white border-0 shadow-sm">
            <h5 class="fw-bold mb-3 text-dark"><i class="bi bi-pencil-square text-warning me-2"></i>Actualizar Entrada Técnico-Operativa</h5>

            @using (Html.BeginForm("Editar", "Comentario", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.ComentarioId)

                <div class="row g-3">
                    <div class="col-12">
                        @Html.LabelFor(m => m.ProyectoId, new { @class = "form-label small fw-bold text-secondary" })
                        @Html.DropDownListFor(m => m.ProyectoId, Model.ListaProyectos, new { @class = "form-select" })
                        @Html.ValidationMessageFor(m => m.ProyectoId, "", new { @class = "text-danger small" })
                    </div>
                    <div class="col-md-6">
                        @Html.LabelFor(m => m.PrioridadId, new { @class = "form-label small fw-bold text-secondary" })
                        @Html.DropDownListFor(m => m.PrioridadId, Model.ListaPrioridades, new { @class = "form-select" })
                        @Html.ValidationMessageFor(m => m.PrioridadId, "", new { @class = "text-danger small" })
                    </div>
                    <div class="col-md-6">
                        @Html.LabelFor(m => m.EstatusId, new { @class = "form-label small fw-bold text-secondary" })
                        @Html.DropDownListFor(m => m.EstatusId, Model.ListaEstatus, new { @class = "form-select" })
                        @Html.ValidationMessageFor(m => m.EstatusId, "", new { @class = "text-danger small" })
                    </div>
                    <div class="col-12">
                        @Html.LabelFor(m => m.Descripcion, new { @class = "form-label small fw-bold text-secondary" })
                        @Html.TextAreaFor(m => m.Descripcion, new { @class = "form-control", @rows = "5" })
                        @Html.ValidationMessageFor(m => m.Descripcion, "", new { @class = "text-danger small" })
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                    <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary px-4">Volver</a>
                    <button type="submit" class="btn btn-sm btn-dark px-4">Confirmar Cambios</button>
                </div>
            }
        </div>
    </div>
</div>