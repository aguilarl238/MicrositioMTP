@model MTPMicrositio.Models.Web.ClientesViewModel
@{
    Layout = "~/Views/Shared/_LayoutPortal.cshtml";
    ViewBag.Title = "Consola Global MTP";
}

@Html.AntiForgeryToken()
<link rel="stylesheet" href="/Content/custom.css">

<style>
    :root {
        --azul-noche: #1B2E4B;
        --verde-esmeralda: #1B7A61;
        --blanco-frio: #F8F9FB;
        --borde-suave: #DDE3EA;
        --texto-secundario: #5A6E85;
    }

    .page-header-mtp {
        margin-bottom: 24px;
        border-bottom: 1px solid var(--borde-suave);
        padding-bottom: 16px;
    }

    .page-title-mtp {
        color: var(--azul-noche);
        font-weight: 500;
        font-size: 22px;
        margin: 0;
    }

    .page-subtitle-mtp {
        color: var(--texto-secundario);
        font-size: 13px;
        margin: 4px 0 0 0;
    }

    /* Tarjeta Contenedora Formulario */
    .form-card-mtp {
        background: #ffffff;
        border-radius: 8px;
        border: 1px solid var(--borde-suave);
        box-shadow: 0 4px 16px rgba(27, 46, 75, 0.03) !important;
        padding: 28px !important;
    }

    /* Grupos de Control */
    .field-group-mtp {
        margin-bottom: 20px;
    }

    .label-mtp {
        color: var(--azul-noche);
        font-weight: 600;
        font-size: 13px;
        margin-bottom: 6px;
        display: block;
    }

    .input-mtp {
        width: 100%;
        background-color: var(--blanco-frio);
        border: 1px solid var(--borde-suave);
        border-radius: 6px;
        padding: 10px 14px;
        font-size: 13px;
        color: var(--azul-noche);
        transition: all 0.2s ease;
    }

        .input-mtp:focus {
            outline: none;
            border-color: var(--verde-esmeralda);
            background-color: #ffffff;
            box-shadow: 0 0 0 3px rgba(27, 122, 97, 0.08);
        }

    /* Interruptores y Checkboxes Ejecutivos */
    .checkbox-container-mtp {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 6px 0;
    }

        .checkbox-container-mtp input[type="checkbox"] {
            width: 16px;
            height: 16px;
            accent-color: var(--verde-esmeralda);
            cursor: pointer;
            margin-top: 2px;
        }

    .checkbox-label-mtp {
        color: var(--azul-noche);
        font-size: 13px;
        cursor: pointer;
        user-select: none;
        line-height: 1.4;
    }

    /* Botonera */
    .btn-mtp-submit {
        background-color: var(--verde-esmeralda);
        color: #ffffff;
        border: none;
        padding: 10px 24px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: background-color 0.2s ease;
    }

        .btn-mtp-submit:hover {
            background-color: #145b48;
        }

    .btn-mtp-cancel {
        background-color: transparent;
        color: var(--texto-secundario);
        border: 1px solid var(--borde-suave);
        padding: 10px 24px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .btn-mtp-cancel:hover {
            background-color: var(--blanco-frio);
            color: var(--azul-noche);
            border-color: var(--azul-noche);
            text-decoration: none;
        }

    .text-danger-mtp {
        color: #D9534F;
        font-size: 11px;
        font-weight: 500;
        margin-top: 4px;
        display: block;
    }
</style>

<div class="container" style="max-width: 600px; margin-top: 1.5rem; margin-bottom: 3rem;">

    <div class="page-header-mtp">
        <h2 class="page-title-mtp">Modificar Expediente Comercial</h2>
        <p class="page-subtitle-mtp">Actualice la información legal, operativa y visual de la cuenta seleccionada.</p>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="form-card-mtp">

            @if (!ViewData.ModelState.IsValid)
            {
                <div style="background-color: #FCE8E6; color: #D9534F; padding: 12px; border-radius: 6px; margin-bottom: 20px; font-size: 13px;">
                    @Html.ValidationSummary(true, "", new { @style = "list-style:none; padding:0; margin:0;" })
                </div>
            }

            <!-- Llaves y campos de control ocultos para mantener integridad estructural -->
            @Html.HiddenFor(model => model.ClienteId)

            <!-- Campo: Nombre Comercial -->
            <div class="field-group-mtp">
                @Html.LabelFor(model => model.Nombre, htmlAttributes: new { @class = "label-mtp" })
                @Html.EditorFor(model => model.Nombre, new { htmlAttributes = new { @class = "input-mtp", placeholder = "Nombre corporativo" } })
                @Html.ValidationMessageFor(model => model.Nombre, "", new { @class = "text-danger-mtp" })
            </div>

            <!-- Campo: Estatus en la Base de Datos -->
            <div class="field-group-mtp">
                @Html.LabelFor(model => model.EstatusId, htmlAttributes: new { @class = "label-mtp" })
                @Html.DropDownListFor(
                    model => model.EstatusId,
                    Model.ListadoEstatus,
                    "--- Seleccione el estatus actual ---",
                    htmlAttributes: new { @class = "input-mtp" }
                )
                @Html.ValidationMessageFor(model => model.EstatusId, "", new { @class = "text-danger-mtp" })
            </div>

            <!-- Campo: URL del Logotipo Institucional -->
            <div class="field-group-mtp">
                @Html.LabelFor(model => model.LogoUrl, htmlAttributes: new { @class = "label-mtp" })
                @Html.EditorFor(model => model.LogoUrl, new { htmlAttributes = new { @class = "input-mtp", placeholder = "https://ejemplo.com/assets/logo.png" } })
                @Html.ValidationMessageFor(model => model.LogoUrl, "", new { @class = "text-danger-mtp" })
            </div>

            <!-- Sección de Cumplimiento y Gobernanza Corporativa -->
            <div class="field-group-mtp" style="background: var(--blanco-frio); padding: 14px; border-radius: 6px; border: 1px solid var(--borde-suave); margin-top: 24px;">
                <span style="font-size: 11px; color: var(--texto-secundario); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; display: block; margin-bottom: 10px;">
                    Validación Jurídica y Control Operativo
                </span>

                <!-- Checkbox: Autorización Legal de Marca -->
                <div class="checkbox-container-mtp mb-2">
                    @Html.CheckBoxFor(model => model.LogoAutorizado, new { id = "LogoAutorizado" })
                    <label for="LogoAutorizado" class="checkbox-label-mtp" style="font-weight: 600;">
                        Confirmar uso legal y autorización firmada de marca corporativa [RF-15]
                    </label>
                </div>
                @Html.ValidationMessageFor(model => model.LogoAutorizado, "", new { @class = "text-danger-mtp", style = "margin-left: 26px; margin-bottom: 10px;" })

                <!-- Checkbox: Estado Activo en Plataforma -->
                <div class="checkbox-container-mtp">
                    @Html.CheckBoxFor(model => model.Activo, new { id = "Activo" })
                    <label for="Activo" class="checkbox-label-mtp">
                        Cuenta habilitada en el entorno comercial operativo
                    </label>
                </div>
                @Html.ValidationMessageFor(model => model.Activo, "", new { @class = "text-danger-mtp", style = "margin-left: 26px;" })
            </div>

            <!-- Botonera de Envío Integrada -->
            <div class="d-flex align-items-center" style="gap: 12px; margin-top: 28px;">
                <button type="submit" class="btn-mtp-submit">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
                    Aplicar Cambios
                </button>
                <a href="@Url.Action("Index")" class="btn-mtp-cancel">
                    Cancelar y Volver
                </a>
            </div>

        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}