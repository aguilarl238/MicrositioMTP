@model IEnumerable<MTPMicrositio.Models.Web.ClientesViewModel>
@{
    Layout = "~/Views/Shared/_LayoutPortal.cshtml";
    ViewBag.Title = "Consola Global MTP";
}

<link rel="stylesheet" href="/Content/Style.css">
<link rel="stylesheet" href="/Content/custom.css">

@Html.AntiForgeryToken()

<style>
    :root {
        --azul-noche: #1B2E4B;
        --verde-esmeralda: #1B7A61;
        --blanco-frio: #F8F9FB;
        --borde-suave: #DDE3EA;
        --texto-secundario: #5A6E85;
    }

    .page-header-mtp {
        margin-bottom: 28px;
        border-bottom: 1px solid var(--borde-suave);
        padding-bottom: 16px;
    }

    .page-title-mtp {
        color: var(--azul-noche);
        font-weight: 500;
        font-size: 24px;
        margin: 0;
    }

    .page-subtitle-mtp {
        color: var(--texto-secundario);
        font-size: 13px;
        margin: 4px 0 0 0;
    }

    /* Botones con Identidad Corporativa */
    .btn-mtp-primary {
        background-color: var(--verde-esmeralda);
        color: #ffffff;
        border: none;
        padding: 10px 20px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        display: inline-block;
        transition: background-color 0.2s ease;
    }

        .btn-mtp-primary:hover {
            background-color: #145b48;
            color: #ffffff;
            text-decoration: none;
        }

    .btn-mtp-outline {
        background-color: transparent;
        color: var(--azul-noche);
        border: 1px solid var(--borde-suave);
        padding: 6px 12px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 500;
        transition: all 0.2s ease;
    }

        .btn-mtp-outline:hover {
            background-color: var(--blanco-frio);
            border-color: var(--azul-noche);
            color: var(--azul-noche);
            text-decoration: none;
        }

    .btn-mtp-action {
        color: var(--texto-secundario);
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        margin-right: 12px;
        transition: color 0.2s ease;
    }

        .btn-mtp-action:hover {
            color: var(--azul-noche);
            text-decoration: underline;
        }

    .btn-mtp-delete {
        color: #D9534F;
        background: none;
        border: none;
        padding: 0;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
    }

        .btn-mtp-delete:hover {
            text-decoration: underline;
        }

    /* Estructura de Tabla Sobria */
    .card-table-container {
        background: #ffffff;
        border-radius: 8px;
        border: 1px solid var(--borde-suave);
        box-shadow: 0 2px 12px rgba(27, 46, 75, 0.03) !important;
    }

    .table-mtp th {
        background-color: var(--azul-noche);
        color: #ffffff;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 12px 16px !important;
        border: none !important;
    }

    .table-mtp td {
        padding: 14px 16px !important;
        border-bottom: 1px solid var(--borde-suave) !important;
        color: var(--azul-noche);
        font-size: 13px;
    }

    .table-mtp tr:last-child td {
        border-bottom: none !important;
    }

    /* Badges de Estado */
    .badge-mtp-active {
        background-color: #E8F7F3;
        color: var(--verde-esmeralda);
        padding: 4px 10px;
        border-radius: 4px;
        font-weight: 600;
        font-size: 11px;
        display: inline-block;
    }

    .badge-mtp-inactive {
        background-color: #FCE8E6;
        color: #D9534F;
        padding: 4px 10px;
        border-radius: 4px;
        font-weight: 600;
        font-size: 11px;
        display: inline-block;
    }
</style>

<div class="page-header-mtp d-flex justify-content-between align-items-center flex-wrap">
    <div>
        <h2 class="page-title-mtp">Gestión de Cuentas Corporativas</h2>
        <p class="page-subtitle-mtp">Consola de administración global de clientes del ecosistema MTP.</p>
    </div>
    <div class="mt-2 mt-sm-0">
        <a href="@Url.Action("Crear")" class="btn-mtp-primary">
            <i class="fa fa-plus mr-1"></i> Registrar Nuevo Cliente
        </a>
    </div>
</div>

<div class="card card-table-container p-0 border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 table-mtp">
            <thead>
                <tr>
                    <th style="width: 45%;">@Html.DisplayNameFor(model => model.Nombre)</th>
                    <th style="width: 20%;">Estado Operativo</th>
                    <th style="width: 35%; text-align: right;">Acciones de Control</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                @Html.Partial("_VisualizadorLogo", item)
                            </div>
                        </td>
                        <td>
                            <span class="@(item.Activo ? "badge-mtp-active" : "badge-mtp-inactive")">
                                @(item.Activo ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td style="text-align: right;">
                            <a href="@Url.Action("Editar", new { id = item.ClienteId })" class="btn-mtp-action">
                                Editar Parámetros
                            </a>

                            <a href="@Url.Action("Index", "Usuarios")" class="btn-mtp-outline mr-2">
                                Asignar Usuarios
                            </a>

                            <button type="button" class="btn-mtp-delete btn-eliminar" data-id="@item.ClienteId" data-nombre="@item.Nombre">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.23.0/sweetalert2.all.min.js"></script>

    <script>
        $(document).ready(function () {
            $('.btn-eliminar').on('click', function () {
                var button = $(this);
                var clienteId = button.data('id');
                var clienteNombre = button.data('nombre');
                var filaTabla = button.closest('tr');
                var token = $('input[name="__RequestVerificationToken"]').val();

                // Alerta de confirmación adaptada a la sobriedad de MTP Internacional
                Swal.fire({
                    title: '¿Confirmar eliminación?',
                    text: "Esta acción revocará los accesos y registros del cliente: " + clienteNombre,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#1B2E4B', // Azul Noche
                    cancelButtonColor: '#5A6E85',  // Texto Secundario
                    confirmButtonText: 'Sí, eliminar',
                    cancelButtonText: 'Cancelar',
                    background: '#ffffff',
                    customClass: {
                        title: 'page-title-mtp',
                        popup: 'border-radius-8'
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("Delete", "Clientes")',
                            type: 'POST',
                            data: {
                                id: clienteId,
                                __RequestVerificationToken: token
                            },
                            success: function (response) {
                                if (response.success) {
                                    Swal.fire({
                                        title: '¡Eliminado!',
                                        text: response.message,
                                        icon: 'success',
                                        confirmButtonColor: '#1B7A61' // Verde Esmeralda
                                    });

                                    filaTabla.fadeOut(400, function () {
                                        $(this).remove();
                                    });
                                } else {
                                    Swal.fire({
                                        title: 'Operación Rechazada',
                                        text: response.message,
                                        icon: 'error',
                                        confirmButtonColor: '#1B2E4B'
                                    });
                                }
                            },
                            error: function () {
                                Swal.fire({
                                    title: 'Error de Red',
                                    text: 'No se pudo establecer comunicación con el servidor central.',
                                    icon: 'error',
                                    confirmButtonColor: '#1B2E4B'
                                });
                            }
                        });
                    }
                });
            });
        });
    </script>
}