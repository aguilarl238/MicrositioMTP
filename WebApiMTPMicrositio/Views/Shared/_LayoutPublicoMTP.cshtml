<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>MTP Internacional | Digital Business Assurance</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="../Content/Style.css">
    @Styles.Render("~/Content/css")
<style>
        /* Estilos del menú principal */
    nav {
        background-color: #1B2E4B; /* Azul solicitado */
    }

    nav ul {
        list-style: none;
        display: flex;
    }

    nav ul li {
        position: relative; /* Necesario para submenús */
    }

    nav ul li a {
        display: block;
        padding: 14px 20px;
        color: white;
        text-decoration: none;
        transition: background 0.3s;
    }

    nav ul li a:hover {
        background-color: #2C4A77; /* Azul más claro al pasar */
    }

    /* Submenús ocultos por defecto */
    nav ul li ul {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        background-color: #1B2E4B;
        min-width: 180px;
        z-index: 1000;
        flex-direction: column;
    }

    nav ul li ul li a {
        padding: 12px 16px;
    }

    /* Mostrar submenú al pasar el ratón */
    nav ul li:hover > ul {
        display: flex;
    }

    /* Responsive: menú vertical en pantallas pequeñas */
    @*@media (max-width: 768px) {
        nav ul {
            flex-direction: column;
        }
        nav ul li ul {
            position: static;
        }
    }*@

</style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-tech-gradient sticky-top border-bottom border-secondary">
        <div class="container">
            <div class="nav-logo"><img src="data:image/png;base64," alt="MTP Internacional" style="height:36px;"></div>
            @*<a class="navbar-brand fw-bold text-uppercase" href="@Url.Action("Index", "Home")">MTP <span class="text-accent">Internacional</span></a>*@
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto fw-semibold">
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Home")">Inicio</a></li>
                    <li class="nav-item">
                        <a class="nav-link">Nosotros ▾</a>
                        <ul>
                            <li><a class="nav-link" href="@Url.Action("QuienesSomos", "Home")">Quiénes Somos</a></li>
                            <li><a class="nav-link" href="@Url.Action("Certificaciones", "Home")">Certificaciones</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link">Servicios ▾</a>
                        <ul>
                            <li><a class="nav-link" href="@Url.Action("Servicios", "Home")">Portafolio de Servicios</a></li>
                            <li><a class="nav-link" href="@Url.Action("Comotrabajamos", "Home")">Modelos de Servicios </a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link">Resultados ▾</a>
                        <ul>
                            <li><a class="nav-link" href="@Url.Action("CasosExito", "Home")">Casos Éxito</a></li>
                            <li><a class="nav-link" href="@Url.Action("Sectores", "Home")">Sectores </a></li>
                        </ul>

                    </li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Contacto", "Home")">Contacto</a></li>
                    @*<li>@Html.ActionLink("API", "Index", "Help", new { area = "" }, new { @class = "nav-link" })</li>*@
                    <li class="nav-item ms-lg-3"><a class="nav-portal" href="@Url.Action("Login", "Portal")">Portal Clientes</a></li>
                </ul>
            </div>
        </div>
    </nav>
    @RenderBody().

<div class="doc-footer">
    MTP Internacional · Mockup Micrositio Corporativo · Referencia visual para desarrollo · Junio 2026
</div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

