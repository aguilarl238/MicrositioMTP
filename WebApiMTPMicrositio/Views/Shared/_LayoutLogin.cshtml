<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iniciar Sesión | Portal de Clientes MTP</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --mtp-dark: #0f172a; /* Slate 900 */
            --mtp-primary: #1e3a8a; /* Azul Marino Corporativo */
            --mtp-accent: #06b6d4; /* Cian Eléctrico Tecnológico */
            --mtp-light: #f8fafc; /* Blanco Grisáceo */
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, var(--mtp-dark) 0%, #1e293b 100%);
            min-height: 100vh;
            color: #ffffff;
        }

        .login-card {
            background-color: #ffffff;
            border: 1px solid rgba(6, 182, 212, 0.2);
            border-radius: 12px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
            transition: border-color 0.3s ease;
        }

            .login-card:hover {
                border-color: var(--mtp-accent);
            }

        .form-control {
            border: 1px solid #cbd5e1;
            padding: 0.75rem 1rem;
            transition: all 0.2s ease;
        }

            .form-control:focus {
                border-color: var(--mtp-accent);
                box-shadow: 0 0 0 0.25rem rgba(6, 182, 212, 0.15);
                color: #1e293b;
            }

        .btn-tech {
            background-color: var(--mtp-primary);
            color: #ffffff;
            font-weight: 600;
            padding: 0.75rem;
            border: none;
            transition: all 0.3s ease;
        }

            .btn-tech:hover {
                background-color: #172554;
                color: var(--mtp-accent);
                box-shadow: 0 4px 12px rgba(6, 182, 212, 0.2);
            }

        .text-accent {
            color: var(--mtp-accent);
        }

        .border-accent-left {
            border-left: 3px solid var(--mtp-accent);
        }
    </style>
</head>
<body>
