        <!-- Campo: Contraseña -->
        <div class="field-group-mtp">
            @Html.LabelFor(m => m.Password, new { @class = "label-mtp" })
            @Html.PasswordFor(m => m.Password, new { @class = "input-mtp", placeholder = "Asigne una clave (Mínimo 6 caracteres)" })
