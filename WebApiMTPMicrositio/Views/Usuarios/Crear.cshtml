        </div>

        <!-- Campo: Confirmar Contraseña -->
        <div class="field-group-mtp" style="margin-bottom: 28px;">
            @Html.LabelFor(m => m.ConfirmarPassword, new { @class = "label-mtp" })
            @Html.PasswordFor(m => m.ConfirmarPassword, new { @class = "input-mtp", placeholder = "Repita la clave asignada arriba" })
            @Html.ValidationMessageFor(m => m.ConfirmarPassword, "", new { @class = "text-danger-mtp" })
        </div>

        <!-- Botonera de Envío y Retorno -->
        <div class="d-flex align-items-center" style="gap: 12px;">
            <button type="submit" class="btn-mtp-submit">
                Guardar Usuario
            </button>
            <a href="@Url.Action("Index", "Usuarios")" class="btn-mtp-cancel">
                Cancelar
            </a>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}