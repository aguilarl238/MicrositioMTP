@model MTPMicrositio.Models.Web.UsuarioViewModel
@{
    Layout = "~/Views/Shared/_LayoutPortal.cshtml";
    ViewBag.Title = "Consola Global MTP";
}

@Html.AntiForgeryToken()
<link rel="stylesheet" href="/Content/Style.css">
<link rel="stylesheet" href="/Content/custom.css">
<style>
    :root {
        --azul-noche: #1B2E4B;
        --verde-esmeralda: #1B7A61;
        --blanco-frio: #F8F9FB;
        --borde-suave: #DDE3EA;
        --texto-secundario: #5A6E85;
    }

    .page-header-mtp {
        margin-bottom: 24px;
        border-bottom: 1px solid var(--borde-suave);
        padding-bottom: 16px;
    }

    .page-title-mtp {
        color: var(--azul-noche);
        font-weight: 500;
        font-size: 22px;
        margin: 0;
    }

    .page-subtitle-mtp {
        color: var(--texto-secundario);
        font-size: 13px;
        margin: 4px 0 0 0;
    }

    /* Tarjeta Contenedora del Formulario */
    .form-card-mtp {
        background: #ffffff;
        border-radius: 8px;
        border: 1px solid var(--borde-suave);
        box-shadow: 0 4px 16px rgba(27, 46, 75, 0.03) !important;
        padding: 28px !important;
    }

    /* Grupos de Control */
    .field-group-mtp {
        margin-bottom: 20px;
    }

    .label-mtp {
        color: var(--azul-noche);
        font-weight: 600;
        font-size: 13px;
        margin-bottom: 6px;
        display: block;
    }

    .input-mtp {
        width: 100%;
        background-color: var(--blanco-frio);
        border: 1px solid var(--borde-suave);
        border-radius: 6px;
        padding: 10px 14px;
        font-size: 13px;
        color: var(--azul-noche);
        transition: all 0.2s ease;
    }

        .input-mtp:focus {
            outline: none;
            border-color: var(--verde-esmeralda);
            background-color: #ffffff;
            box-shadow: 0 0 0 3px rgba(27, 122, 97, 0.08);
        }

    /* Botonera Operativa */
    .btn-mtp-submit {
        background-color: var(--verde-esmeralda);
        color: #ffffff;
        border: none;
        padding: 10px 24px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }

        .btn-mtp-submit:hover {
            background-color: #145b48;
        }

    .btn-mtp-cancel {
        background-color: transparent;
        color: var(--texto-secundario);
        border: 1px solid var(--borde-suave);
        padding: 10px 24px;
        border-radius: 6px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.2s ease;
    }

        .btn-mtp-cancel:hover {
            background-color: var(--blanco-frio);
            color: var(--azul-noche);
            border-color: var(--azul-noche);
            text-decoration: none;
        }

    /* Mensajes de Validación y Alertas */
    .alert-mtp-danger {
        background-color: #FCE8E6;
        color: #D9534F;
        border: 1px solid rgba(217, 83, 79, 0.1);
        font-size: 13px;
        padding: 12px 16px;
        border-radius: 6px;
    }

    .text-danger-mtp {
        color: #D9534F;
        font-size: 11px;
        font-weight: 500;
        margin-top: 4px;
        display: block;
    }
</style>

<div class="container" style="max-width: 600px; margin-top: 1.5rem; margin-bottom: 3rem;">

    <!-- Encabezado del Módulo -->
    <div class="page-header-mtp">
        <h2 class="page-title-mtp">Registrar Usuario</h2>
        <p class="page-subtitle-mtp">Configure las credenciales de identidad iniciales para su posterior sincronización con el API REST.</p>
    </div>

    <!-- Feedback de Éxito Operativo -->
    @if (TempData["Mensaje"] != null)
    {
        <div class="alert alert-success bg-gradient border-0 text-white mb-4" style="background-color: var(--verde-esmeralda); font-size: 13px; padding: 12px 16px; border-radius: 6px;" role="alert">
            ✔ @TempData["Mensaje"]
        </div>
    }

    @using (Html.BeginForm("Crear", "Usuarios", FormMethod.Post, new { @class = "form-card-mtp" }))
    {
        @Html.AntiForgeryToken()

        if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-mtp-danger mb-4">
                @Html.ValidationSummary(false, "", new { @style = "list-style:none; padding:0; margin:0;" })
            </div>
        }

        <!-- Campo: Nombre -->
        <div class="field-group-mtp">
            @Html.LabelFor(m => m.Nombre, new { @class = "label-mtp" })
            @Html.TextBoxFor(m => m.Nombre, new { @class = "input-mtp", placeholder = "Nombre completo del colaborador" })
            @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger-mtp" })
        </div>

        <!-- Campo: Correo Electrónico -->
        <div class="field-group-mtp">
            @Html.LabelFor(m => m.Email, new { @class = "label-mtp" })
            @Html.TextBoxFor(m => m.Email, new { @class = "input-mtp", type = "email", placeholder = "usuario@mtp.com.mx" })
            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger-mtp" })
        </div>
